{
  "name": "taskflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TaskFlow — Ionic + Vue + Pinia training app (Day 6 tabs, Day 7 tabs + detail)",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest",
    "lint": "eslint",
    "sync": "npm run build && cap sync",
    "android": "npm run build && cap sync android && cap run android",
    "android:open": "npm run build && cap sync android && cap open android",
    "ios": "npm run build && cap sync ios && cap run ios",
    "ios:open": "npm run build && cap sync ios && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/core": "8.4.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.5",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@ionic/pwa-elements": "^3.4.0",
    "@ionic/vue": "8.8.13",
    "@ionic/vue-router": "8.8.13",
    "ionicons": "^7.0.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.3.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "@vitejs/plugin-legacy": "^5.0.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/test-utils": "^2.3.0",
    "cypress": "^13.5.0",
    "eslint": "^8.35.0",
    "eslint-plugin-vue": "^9.9.0",
    "vite": "~5.4.0",
    "vitest": "^0.34.6"
  }
}
